name: Build Paper Plugin

on:
  push:
    branches: [ "main" ] # Déclenche la compilation à chaque push sur la branche main
  pull_request:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Récupérer le code source
      uses: actions/checkout@v4

    - name: Configurer Java 21 (Requis pour la 1.21.1)
      uses: actions/setup-java@v4
      with:
        distribution: 'temurin'
        java-version: '21'
        cache: 'maven'

    - name: Compiler le plugin avec Maven
      run: mvn clean package

    - name: Télécharger le fichier .jar généré
      uses: actions/upload-artifact@v4
      with:
        name: TNT-Bow-Plugin
        path: target/*.jar
